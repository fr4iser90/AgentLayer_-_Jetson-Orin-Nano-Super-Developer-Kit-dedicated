# Kopieren nach .env und anpassen ( .env nicht committen — Root-.gitignore )
#
# Docker Compose lädt diese Datei automatisch für Variablen in compose.yaml.
#
# Lokaler Agent ohne Docker: PYTHONPATH = Repo-Root (``apps.*`` und ``plugins.*``).
#   export PYTHONPATH="$PWD"

# --- PostgreSQL (Service postgres + Default für DATABASE_URL) ---
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent
POSTGRES_DB=agent

# Option A: volle URL (Compose übergibt sie an den Agent).
# Option B: Zeile auskommentieren/löschen — dann nutzt der Agent POSTGRES_* unten + PGHOST=postgres aus compose.yaml.
# Bei Sonderzeichen im Passwort: URL-encoden.
DATABASE_URL=postgresql://agent:agent@postgres:5432/agent

# # --- Agent execution class (Docker-bound vs host-class tools) ---
# sandbox (default): all tools run with effective execution_context container (ignores per-package host).
# host: per-package operator policy + manifest may use host / remote / browser where allowed.
# Admin → Interfaces can set a DB override (cleared = use this env value again).
AGENT_MODE=sandbox

# --- Dashboard gallery uploads (binary files on disk; metadata in dashboard_files) ---
# Max file size per upload when operator DB override is unset (Admin → Interfaces → Dashboard uploads).
# AGENT_WORKSPACE_UPLOAD_MAX_MB=10
# Directory; default: AGENT_DATA_DIR/dashboard_uploads (typically /data/dashboard_uploads in Docker).
# AGENT_WORKSPACE_UPLOAD_DIR=/data/dashboard_uploads
# Comma-separated allowlist; must match magic-byte sniff on the server.
# AGENT_WORKSPACE_UPLOAD_ALLOWED_MIME=image/jpeg,image/png,image/gif,image/webp

# --- AUTH ---
# JWT Secret Key, generieren mit: openssl rand -hex 32
# Einmal generieren, für immer behalten! Nicht ändern nach erstem Start.
AGENT_JWT_SECRET=

# Refresh cookie Secure flag. Omit = auto: true when URL scheme is https or X-Forwarded-Proto is https (Traefik).
# Force: AGENT_COOKIE_SECURE=true | false (e.g. false for plain-HTTP local dev even behind a misconfigured proxy).
# AGENT_COOKIE_SECURE=true

# Erster Admin (leere DB): beide setzen vor dem ersten Start (Pflicht). Danach entfernen und Passwort in der UI ändern.
# AGENT_INITIAL_ADMIN_EMAIL=
# AGENT_INITIAL_ADMIN_PASSWORD=

# RAG + memory (facts/notes) are configured in the DB via Admin → Interfaces (operator_settings), not .env.

# --- Ollama ---
OLLAMA_BASE_URL=http://ollama:11434
# Default model when client omits ``model`` or override is disabled (also profile fallback).
# OLLAMA_DEFAULT_MODEL=nemotron-3-nano:4b
#
# Hybrid model routing (optional): per-profile Ollama ids; empty = use OLLAMA_DEFAULT_MODEL for that profile.
# Auto: multimodal image parts in messages → vlm profile (text-only model overrides are ignored for that request).
# AGENT_MODEL_PROFILE_DEFAULT=
# AGENT_MODEL_PROFILE_VLM=llava:13b
# If Ollama returns "does not support tools" for a vision model, one retry is sent without tools[] for that round.
# AGENT_MODEL_PROFILE_AGENT=
# AGENT_MODEL_PROFILE_CODING=
# AGENT_ALLOW_MODEL_OVERRIDE=true
# Comma-separated roles allowed to use body ``model`` / X-Agent-Model-Override (empty = any authenticated user).
# AGENT_MODEL_OVERRIDE_ROLES=admin
# Allow anonymous optional-route callers to override (insecure on exposed hosts).
# AGENT_MODEL_OVERRIDE_ANONYMOUS=false
COMFYUI_BASE_URL=http://localhost:8188/
# Tools + Image Studio (same server; no trailing slash). Falls back to COMFYUI_BASE_URL if unset.
# COMFYUI_URL=http://comfyui:8188
# Optional Studio timeouts (seconds)
# AGENT_STUDIO_COMFY_SUBMIT_TIMEOUT=60
# AGENT_STUDIO_COMFY_POLL_TIMEOUT=180
# AGENT_STUDIO_COMFY_POLL_INTERVAL=2
# Max bytes per output image embedded in JSON (default 25MB)
# AGENT_STUDIO_MAX_OUTPUT_BYTES=25000000
# Comma-separated checkpoint filenames allowed for Studio (intersected with ComfyUI /object_info). Omit = all Comfy checkpoints.
# AGENT_STUDIO_ALLOWED_CKPTS=model_a.safetensors,model_b.safetensors
# Cache for GET /v1/studio/comfy/checkpoints (seconds)
# AGENT_STUDIO_CKPT_LIST_CACHE_SEC=60

# --- Agent HTTP (Host-Port) ---
AGENT_HTTP_PORT=8088

# --- Agent ---
# Max. Tool-Schleifen pro Chat-Request (create_tool → list → read → update …). Default 8; lokal/Jetson oft 12–20.
AGENT_MAX_TOOL_ROUNDS=8
# Background thread: run persisted ``scheduler_jobs`` (execution_target=server_periodic). false = aus.
# AGENT_SCHEDULER_JOBS_SERVER_WORKER=true
# Max. verschachtelte Tool-Aufrufe (Plugin ruft per invoke_registered_tool ein anderes Tool, das wieder …). Default 24.
# AGENT_TOOL_CHAIN_MAX_DEPTH=24
#
# Capability gate (ADR docs/adr/0003-capability-governance.md): comma-separated capability ids (lowercase).
# Empty = that rule off. Applied in run_tool (chat + POST /tools/run + POST /{tool_name}).
# AGENT_CAPABILITY_GATE_ALLOW=
# AGENT_CAPABILITY_GATE_BLOCK=
# AGENT_CAPABILITY_GATE_CONFIRM=
# Chat JSON: agent_capability_confirm lists confirmed ids. HTTP: X-Agent-Capability-Confirm: id1,id2
# Vor replace_tool / update_tool / create_tool (Overwrite): Kopie der alten .py (UTC-Präfix im Dateinamen)
# AGENT_TOOLS_BACKUP_ENABLED=true
# AGENT_TOOLS_BACKUP_DIR=/data/tools/.tool_backups
# Sonst Default: AGENT_DATA_DIR/tool_backups (= /data/tool_backups im Container)
# AGENT_TOOLS_BACKUP_DIR=/data/tool_backups
# --- Identity (user + tenant) — Bearer only (no spoofable identity headers) ---
# Chat, tools, RAG, user APIs: ``Authorization: Bearer`` must be a JWT (after /auth/login) or a user API key.
# ``users.tenant_id`` in PostgreSQL is the tenant for that user (tool allowlists use the same numeric ids as ``tenants.id``).
# Pro-User-Geheimnisse verschlüsseln (Fernet, nur Betreiber): python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Niemals ins Git. Endnutzer: Tool register_secrets (OTP+curl). Siehe TOOLS.md → User secrets.
# AGENT_SECRETS_MASTER_KEY=
# Optional: öffentliche Agent-URL für curl-Vorlagen (register_secrets / secrets_help).
# Nicht-loopback ``http://`` wird in generierten curl-URLs zu ``https://`` umgeschrieben; lokal bleibt http://127.0.0.1 möglich.
# AGENT_PUBLIC_URL=https://agent.example.com
#
# POST /v1/user/secrets/register-with-otp: Rate-Limit (pro Uvicorn-Prozess; Client = erstes X-Forwarded-For oder Remote-IP).
# AGENT_OTP_REGISTER_RATE_LIMIT_MAX=30
# AGENT_OTP_REGISTER_RATE_LIMIT_WINDOW_SEC=60
# AGENT_CONTENT_TOOL_FALLBACK=true
# (auch: replace_tool({...}) / update_tool({...}) als Klartext + Nemotron <...begin/end...>-Zeilen, wenn JSON gültig)
# Pro Ollama-Runde: INFO mit reply=TOOLS vs TEXT_NO_TOOLS, ctx_msgs, grobe ctx_text_chars (Summe sichtbarer Texte),
# content_json_fallback (JSON im Content statt native tool_calls). Bei sehr großem Kontext: LARGE_CTX-Hinweis.
# AGENT_LOG_LLM_ROUNDS=true
# Optional: erste N Zeichen der Assistant-Antwort (redigiert appid=/Bearer); 0=aus
# AGENT_LOG_ASSISTANT_PREVIEW_CHARS=0
# Schwellwert für LARGE_CTX im Log (Zeichen, nur Metrik)
# AGENT_LOG_LARGE_CONTEXT_CHARS=120000
# Serialisierte tools[] vor chat/completions: Zeichen + grobe Token-Schätzung (chars/4..chars/3)
# AGENT_LOG_TOOLS_REQUEST_ESTIMATE=true
# AGENT_CORS_ORIGINS=*

# --- Tools an Ollama (merged Registry) ---
# Nach Tool-Antworten die wie HTTP-Fehler aussehen (400/401/…, httpx): kurzer System-Hinweis
# (read_tool → search_web → replace_tool). Abschalten: false
# AGENT_TOOL_HTTP_ERROR_RECOVERY_HINTS=true
# Letzte User-Message: Teilstrings aus Tool-Modulen → nur Tools dieser Kategorie (+ Introspection: list_tool_categories, list_tools_in_category, list_available_tools, get_tool_help).
# Pro Modul: TOOL_DOMAIN (Router-Kategorie) + optional TOOL_TRIGGERS (sonst Trigger = TOOL_ID kleingeschrieben).
# Optional für list_tool_categories: TOOL_LABEL, TOOL_DESCRIPTION (erstes Modul pro Kategorie gewinnt).
# Reihenfolge bei mehreren Treffern: optional AGENT_TOOL_DOMAIN_ORDER (Komma), sonst Scan-Reihenfolge der Module.
# AGENT_TOOL_DOMAIN_ORDER=gmail,github,dashboard
#
# Optional (HTTP): nach Router-Kategorien zusätzlich auf ``tools_meta.domain`` filtern.
# Wert z. B. fishing | hunting | survival. Module mit ``TOOL_DOMAIN=shared`` (z. B. outdoor_environment_snapshot) bleiben immer drin.
# Header: X-Agent-Tool-Domain — oder JSON-Body ``TOOL_DOMAIN`` (wird nicht an Ollama durchgereicht).
# Mit AGENT_ROUTER_STRICT_DEFAULT=true und ohne Kategorien-Treffer wird Domain-Filter übersprungen (sonst nur Introspection).
#
# Router strict default (good for small models like Nemotron 4B):
# true = no text/header/body category match → only minimal introspection tools in tools[] (not the full merged list).
# true = unknown category ids from header/body → minimal set, not full list. false = legacy (full list in those cases).
# AGENT_ROUTER_STRICT_DEFAULT=false
# Comma-separated tool names for that minimal set; empty = list_tool_categories, list_tools_in_category, list_available_tools, get_tool_help
# AGENT_ROUTER_MINIMAL_TOOLS=
#
# Capability-first (zusätzlich zu Router/Domain): Chat-JSON-Body ``agent_capability_hints`` = Liste von Fähigkeiten
# (z. B. ["mail.read","weather.get"]). Filtert merged tools[] auf Module mit passendem ``TOOL_CAPABILITIES`` / per-tool override.
# Index für Clients: GET /v1/capabilities (schema_version). Siehe docs/adr/0001-tool-and-agent-architecture.md
#
# Nach dem Routing diese registrierten Tool-Funktionsnamen aus tools[] entfernen (Komma). Introspection-Tools sind nicht ausgenommen.
# AGENT_TOOLS_DENYLIST=
#
# --- Tools (nur Verzeichnis-Scan, keine feste Tool-Liste im Code) ---
# Optional: nur diese Ordner (Komma), sonst Standard = plugins/tools + plugins/workflows im Image + AGENT_TOOLS_EXTRA_DIR
# AGENT_TOOL_DIRS=/app/plugins/tools,/data/tools
# AGENT_TOOLS_EXTRA_DIR=/data/tools
# AGENT_TOOLS_ALLOWED_SHA256=
# Große String-Args in tool_invocations ausblenden (Komma), Default: source
# AGENT_TOOL_LOG_REDACT_KEYS=source
# create_tool: AGENT_CREATE_TOOL_ENABLED=true genügt für Pfad /data/tools (Default im Code, wenn EXTRA_DIR leer).
# Im compose trotzdem Host-Ordner mounten, z. B. ./plugins/tools/agent/agent_created:/data/tools:rw (Docker mountet nicht „von selbst“).
# Nur nötig, wenn du einen anderen Pfad willst: AGENT_TOOLS_EXTRA_DIR=/irgendwo
# Codegen braucht Ollama + gepulltes Modell (Default im Code: qwen2.5-coder:7b — unabhängig vom Chat-Modell in der UI).
# AGENT_CREATE_TOOL_ENABLED=false
# AGENT_CREATE_TOOL_MAX_BYTES=120000
# Ohne ``source``: Ollama schreibt Modul aus tool_name (siehe create_tool). Modell + Timeout:
# AGENT_CREATE_TOOL_CODEGEN_MODEL=qwen2.5-coder:7b
# AGENT_CREATE_TOOL_CODEGEN_TIMEOUT=120
# Codegen darf HTTP (OpenWeather etc.): Keys nur als Env im Container, im Tool os.environ.get("…")
# AGENT_CREATE_TOOL_CODEGEN_ALLOW_NETWORK=false
# Codegen auto-retry: Ollama-Versuche bei Validierungs- oder test_tool-Fehler (Default 1 = aus; z. B. 4)
# AGENT_CREATE_TOOL_CODEGEN_MAX_ATTEMPTS=1
# OpenWeather: eingebautes Tool ``openweather_current`` (plugins/tools/agent/external/openweather) + dynamische Tools
# OPENWEATHER_API_KEY=

# --- Web-Suche (Tool web_search: search_web, deep_search) ---
# Ohne Keys: Fallback ddgs-Metasuche (inoffiziell, kann ausfallen). Abschalten:
# AGENT_DISABLE_DDG_SEARCH=true
# TAVILY_API_KEY=
# BRAVE_SEARCH_API_KEY=
# AGENT_SEARCH_TIMEOUT=45
# AGENT_SEARCH_MAX_RAW_CHARS=12000
# deep_search ohne Tavily: Snippets + Seitenabruf wenn robots.txt erlaubt
# AGENT_DISABLE_FETCH_DEEP=false
# AGENT_ROBOTS_STRICT=false
# AGENT_FETCH_USER_AGENT=JetpackAgentLayer/1.0 (private)
# AGENT_FETCH_MAX_BYTES=2000000
# AGENT_ROBOTS_CACHE_TTL=3600
# Nur diese Hosts fetchen (Komma, Suffix-Match: docs.godotengine.org erlaubt mit godotengine.org)
# AGENT_FETCH_DOMAIN_ALLOWLIST=godotengine.org,example.com
# X-Robots-Tag / meta robots noindex respektieren (Default an)
# AGENT_RESPECT_META_ROBOTS=true

# --- Lokale Dateien (Paket local_files, Tools fs_*) ---
# Kein AGENT_WORKSPACE_ROOT: Pfade sind absolut oder relativ zum Arbeitsverzeichnis des Agent-Prozesses.
# Docker: ggf. cwd setzen oder Verzeichnisse mounten; Grenzen = OS + execution_context (Admin).
# Optionale Limits (Defaults in src/core/config.py):
# AGENT_WORKSPACE_MAX_FILE_BYTES=1200000
# AGENT_WORKSPACE_MAX_LIST_ENTRIES=500
# AGENT_WORKSPACE_MAX_GLOB_FILES=2000
# AGENT_WORKSPACE_MAX_READ_LINES=8000
# AGENT_WORKSPACE_MAX_SEARCH_FILES=2000
# AGENT_WORKSPACE_MAX_SEARCH_MATCHES=100
# AGENT_WORKSPACE_SEARCH_MAX_FILE_BYTES=400000

# --- Sonstige Tool-APIs ---
# GitHub (Tool github_*): read-only REST. Fine-grained PAT empfohlen. Alternativ pro Nutzer Secret `github_pat`.
# GITHUB_TOKEN=
# SERPAPI_API_KEY=


# --- Interfaces / Discord ---
# Users: link numeric Discord user id → Web UI **Settings → Connections** (Alembic ``schema_002``).
# Admins: in-process Discord bot (same container as agent-layer) → Web UI **Admin → Interfaces** (Alembic ``schema_003``). No extra Docker service or DISCORD_TOKEN in .env required for that path.
# Optional: local debug script ``interfaces/discord/bot.py`` (see that folder’s README).