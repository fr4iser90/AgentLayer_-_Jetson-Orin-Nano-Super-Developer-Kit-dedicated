{
  "kind": "pets",
  "description": "Haustier-Steckbrief mit Gesundheits- und Termin-Feldern.",
  "ui_layout": {
    "version": 1,
    "blocks": [
      {
        "id": "pets-hero",
        "type": "hero",
        "grid": { "x": 0, "y": 0, "w": 12, "h": 8 },
        "props": { "dataPath": "hero", "title": "Hero" }
      },
      {
        "id": "pets-table",
        "type": "table",
        "grid": { "x": 0, "y": 8, "w": 12, "h": 10 },
        "props": {
          "dataPath": "pets",
          "columns": [
            { "field": "name", "kind": "text", "label": "Name" },
            { "field": "species", "kind": "text", "label": "Art / Rasse" },
            { "field": "birthday", "kind": "text", "label": "Geburtstag (YYYY-MM-DD)" },
            {
              "field": "vaccinations",
              "kind": "text",
              "label": "Impfungen (letzte / nächste)"
            },
            {
              "field": "deworming",
              "kind": "text",
              "label": "Entwurmung (letzte / nächste)"
            },
            {
              "field": "vet",
              "kind": "text",
              "label": "Tierarzt / Sonstiges"
            }
          ]
        }
      },
      {
        "id": "pets-albums-hint",
        "type": "markdown",
        "grid": { "x": 0, "y": 18, "w": 12, "h": 3 },
        "props": {
          "dataPath": "albums_intro",
          "placeholder": "Mehr Alben: Layout bearbeiten → weiteren Gallery-Block einfügen → dataPath z. B. albums.2.photos setzen und in den Rohdaten ein drittes Objekt in „albums“ ergänzen (id, title, photos)."
        }
      },
      {
        "id": "pets-album-0",
        "type": "gallery",
        "grid": { "x": 0, "y": 21, "w": 6, "h": 8 },
        "props": { "dataPath": "albums.0.photos", "title": "Album 1" }
      },
      {
        "id": "pets-album-1",
        "type": "gallery",
        "grid": { "x": 6, "y": 21, "w": 6, "h": 8 },
        "props": { "dataPath": "albums.1.photos", "title": "Album 2" }
      },
      {
        "id": "pets-notes",
        "type": "markdown",
        "grid": { "x": 0, "y": 29, "w": 12, "h": 4 },
        "props": {
          "dataPath": "notes",
          "placeholder": "Notizen zu Futter, Medikamenten, Verhalten…"
        }
      }
    ]
  },
  "initial_data": {
    "hero": { "url": "", "caption": "", "headline": "" },
    "pets": [],
    "albums_intro": "Zwei Fotoalben sind vorkonfiguriert (unten). Bilder: Workspace-Upload oder URL (**wsfile:**…). Weitere Alben: Layout bearbeiten → Gallery-Block duplizieren → dataPath z. B. albums.2.photos; unter **albums** im JSON ein weiteres Objekt mit id, title, photos anlegen.",
    "albums": [
      { "id": "album_1", "title": "Album 1", "photos": [] },
      { "id": "album_2", "title": "Album 2", "photos": [] }
    ],
    "notes": ""
  }
}
